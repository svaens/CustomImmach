# Docker image used for the uploader.
IMMICH_CLI_IMAGE=ghcr.io/immich-app/immich-cli:latest

# Immich CLI expects the API endpoint.
IMMICH_INSTANCE_URL=https://localhost/api
IMMICH_API_KEY=ScG2Vmg4NOcznkuPsXC7mVb70t7nCj7nTZaElu2Kg

# Upload behavior.
IMMICH_UPLOAD_CONCURRENCY=5
IMMICH_AUTO_CREATE_ALBUM=true
IMMICH_INCLUDE_HIDDEN=false

# Optional glob ignores, space-separated.
IMMICH_IGNORE_PATTERNS=
